# ─── RingCentral ─────────────────────────────────────────────────────────────
# From https://developers.ringcentral.com → My Apps → your app → Credentials
RC_CLIENT_ID=your_ringcentral_client_id
RC_CLIENT_SECRET=your_ringcentral_client_secret

# JWT token from RingCentral Developer Console → Credentials → Create JWT
RC_JWT=your_ringcentral_jwt_token

# Use https://platform.ringcentral.com for production
# Use https://platform.devtest.ringcentral.com for sandbox
RC_SERVER_URL=https://platform.ringcentral.com

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# From https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── GoHighLevel ─────────────────────────────────────────────────────────────
# From GHL → Settings → Integrations → API Key  (or a Private Integration Token)
GHL_API_KEY=your_ghl_api_key

# From GHL → Settings → Business Info → Location ID
GHL_LOCATION_ID=your_ghl_location_id

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# Public URL of this server (used when registering the RingCentral webhook)
# Example: https://ghl-ringcentral.onrender.com
SERVER_URL=https://your-server.onrender.com
